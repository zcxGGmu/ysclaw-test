+    # Quad-round 19: rounds 76-79 (Parity, K=0xCA62C1D6)
+    @{[vsha1parity_vv $V10, $V6, $V15]}
+    @{[vsha1parity_vv $V9, $V10, $V16]}
+    @{[vsha1parity_vv $V8, $V9, $V17]}
+    @{[vsha1parity_vv $V7, $V8, $V18]}
+    @{[vsha1parity_vv $V6, $V7, $V19]}
+
+    # H' = H + delta (add initial state back)
+    @{[vadd_vv $V6, $V26, $V6]}
+    @{[vadd_vv $V7, $V27, $V7]}
+    @{[vadd_vv $V8, $V28, $V8]}
+    @{[vadd_vv $V9, $V29, $V9]}
+    @{[vadd_vv $V10, $V30, $V10]}
+
+    bnez $NUM, L_round_loop
+
+    # Store final state back to context {h0,h1,h2,h3,h4}
+    # Each lane of V6-V10 holds one state word for one block.
+    # For SHA1, the result is the state after processing ALL blocks.
+    # We extract lane 0 (first block) since all 4 parallel blocks
+    # start from the same initial state and produce the same final hash.
+
+    # Extract lane 0 from each state vector and store
+    @{[vsetivli "zero", 1, "e32", "m1", "ta", "ma"]}
+    @{[vslidedown_vi $V11, $V6, 0]}
+    @{[vse32_v $V11, $CTX]}
+    addi $CTX, $CTX, 4
+    @{[vslidedown_vi $V11, $V7, 0]}
+    @{[vse32_v $V11, $CTX]}
+    addi $CTX, $CTX, 4
+    @{[vslidedown_vi $V11, $V8, 0]}
+    @{[vse32_v $V11, $CTX]}
+    addi $CTX, $CTX, 4
+    @{[vslidedown_vi $V11, $V9, 0]}
+    @{[vse32_v $V11, $CTX]}
+    addi $CTX, $CTX, 4
+    @{[vslidedown_vi $V11, $V10, 0]}
+    @{[vse32_v $V11, $CTX]}
+
+    ret
+.size sha1_block_data_order_zvknha,.-sha1_block_data_order_zvknha
+___
+
+print $code;
+
+close STDOUT or die "error closing STDOUT: $!";
