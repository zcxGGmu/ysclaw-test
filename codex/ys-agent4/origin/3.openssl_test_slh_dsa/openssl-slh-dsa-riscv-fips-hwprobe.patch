diff --git a/doc/man3/OPENSSL_riscvcap.pod b/doc/man3/OPENSSL_riscvcap.pod
index 3113b98..c5d9a63 100644
--- a/doc/man3/OPENSSL_riscvcap.pod
+++ b/doc/man3/OPENSSL_riscvcap.pod
@@ -205,6 +205,27 @@ Only enable the vector extension:
 
  export OPENSSL_riscvcap="rv64gc_v"
 
+Enable the RISC-V Zbb SHA-2 implementations for dispatcher testing:
+
+ export OPENSSL_riscvcap="rv64gc_zbb"
+
+Enable the RISC-V vector SHA-256 implementation for dispatcher testing:
+
+ export OPENSSL_riscvcap="rv64gc_v_zvkb_zvknha"
+
+Enable the RISC-V vector SHA-512 implementation for dispatcher testing:
+
+ export OPENSSL_riscvcap="rv64gc_v_zvkb_zvknhb"
+
+These SHA-specific overrides are intended for diagnostics and benchmarking.
+They affect run-time dispatched implementations and do not change the
+compiler-selected base architecture, the ELF Tag_RISCV_arch value, or enable
+compile-time C<__riscv_zbb> code generation. Vector length remains detected
+from hardware and is not overridden by these examples. For normal Linux
+execution, prefer hwprobe-detected capabilities over setting SHA-specific
+overrides. Current RISC-V SHA crypto dispatch covers SHA-256 and SHA-512
+paths; it does not add a RISC-V SHA-1 crypto dispatch path.
+
